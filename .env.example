# ============================================================
# Dental Practice Chatbot — Environment Variables
# Copy this file to .env and fill in the values below.
# ============================================================

# --- Gemini LLM ---
# Get your free API key at: https://aistudio.google.com/apikey
# 1. Sign in with your Google account
# 2. Click "Create API Key"
# 3. Copy the key and paste it below
GEMINI_API_KEY=your_gemini_api_key_here

# --- Database ---
# SQLite (default for dev) — no setup needed, file is auto-created.
# For Postgres (prod): postgresql://user:pass@host:5432/dental_db
DATABASE_URL=sqlite:///./data/dental.db

# --- Redis ---
# Used for conversation state caching (30-min TTL).
# Start Redis via: docker-compose up -d
# Falls back to in-memory dict if Redis is unavailable.
REDIS_URL=redis://localhost:6379

# --- ChromaDB ---
# Directory where ChromaDB persists vector embeddings.
# No setup needed — directory is auto-created on first run.
CHROMA_PERSIST_DIR=./data/chroma

# --- JWT Auth ---
# Secret key for signing JWT tokens. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# IMPORTANT: Change this from the default in production!
JWT_SECRET_KEY=change-me-to-a-random-secret

# --- Concurrency ---
# Max parallel LLM API calls (prevents rate limiting).
# Gemini free tier: start with 10, lower if you hit 429 errors.
MAX_CONCURRENT_LLM_CALLS=10

# --- Frontend ---
# Used by Docker Compose to set the API URL at Next.js build time.
# For local dev, also copy: cp apps/frontend/.env.local.example apps/frontend/.env.local
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Debug ---
# Set to true for verbose logging. Set to false in production.
DEBUG=true
